# Database
DATABASE_URL=confydex.db

# Data storage
DATA_DIR=./data

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Search weights (0.0 to 1.0)
KEYWORD_WEIGHT=0.5
SEMANTIC_WEIGHT=0.5

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (dev only)
FRONTEND_PORT=5173

# Upload directory
UPLOAD_DIR=./uploads

# LLM Provider (openai, anthropic, or opencode-go)
LLM_PROVIDER=opencode-go
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
OPENCODE_GO_API_KEY=your-opencode-go-key-here
OPENCODE_GO_MODEL=glm-5
